# ── Server ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/flareguard

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# ── Shopify App Credentials ──────────────────────────
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_SCOPES=write_script_tags,read_script_tags,write_themes,read_themes
SHOPIFY_APP_URL=https://your-app.onrender.com

# ── Email (Nodemailer) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=FlareGuard <noreply@flareguard.app>

# ── Plans ────────────────────────────────────────────
FREE_REDIRECT_LIMIT=500
